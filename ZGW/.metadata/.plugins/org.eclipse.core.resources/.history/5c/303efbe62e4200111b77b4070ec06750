#ifndef CAN_H_
#define CAN_H_

#include "IfxCan_Can.h"
#include <stdint.h>
#include <stdbool.h>

/* ================= CONFIG ================= */
#define CAN_MAX_DLC                8u
#define CAN_RX_BUFFER_COUNT       16u
#define CAN_TX_BUFFER_COUNT       16u

typedef uint32 Can_IdType;
typedef uint8  Can_HwHandleType;

/* ================= TYPES ================= */

typedef struct
{
    Can_IdType CanId;
    Can_HwHandleType Hoh;
    uint8 ControllerId;
} Can_HwType;

typedef struct
{
    uint8 *SduDataPtr;
    uint8 SduLength;
} PduInfoType;

typedef uint32 PduIdType;

typedef enum
{
    CAN_UNINIT = 0,
    CAN_READY
} Can_StateType;

/* ================= CALLBACK ================= */
void CanIf_RxIndication(const Can_HwType* Mailbox,
                        const PduInfoType* PduInfoPtr);

/* ================= API ================= */
void Can_Init(void);
void Can_MainFunction(void);

bool Can_Write(Can_IdType id, const uint8 *data, uint8 dlc);

/* ISR entry (called from vector table) */
void Can_IsrRxHandler(void);

/* ================= INTERNAL ================= */
typedef struct
{
    IfxCan_Can canModule;
    IfxCan_Can_Node canNode;
    IfxCan_Can_NodeConfig nodeConfig;
    IfxCan_Message txMsg;
    IfxCan_Message rxMsg;

    uint8 txData[CAN_MAX_DLC];
    uint8 rxData[CAN_MAX_DLC];

} Can_DriverType;

extern Can_DriverType Can_Driver;

#endif
