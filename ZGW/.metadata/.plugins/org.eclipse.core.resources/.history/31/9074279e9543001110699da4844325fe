#ifndef TCPIPH_H
#define TCPIPH_H

#include "lwip/sockets.h"
#include "lwip/netdb.h"
#include "lwip/ip_addr.h"
#include <stdint.h>

typedef int32_t TcpIp_SocketIdType;

#define TCPIP_INVALID_SOCKET   (-1)

void TcpIp_Init(void);
void TcpIp_MainFunction(void);

TcpIp_SocketIdType TcpIp_Create(uint8_t tcp);
int32_t TcpIp_Bind(TcpIp_SocketIdType sock, uint16_t port);
int32_t TcpIp_Listen(TcpIp_SocketIdType sock);
TcpIp_SocketIdType TcpIp_Accept(TcpIp_SocketIdType sock);

int32_t TcpIp_Connect(TcpIp_SocketIdType sock, uint32_t ip, uint16_t port);

int32_t TcpIp_Send(TcpIp_SocketIdType sock, const uint8_t *data, uint16_t len);
int32_t TcpIp_Recv(TcpIp_SocketIdType sock, uint8_t *data, uint16_t len);

void TcpIp_Close(TcpIp_SocketIdType sock);

#endif
