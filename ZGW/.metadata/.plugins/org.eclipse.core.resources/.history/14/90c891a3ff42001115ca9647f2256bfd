/* DoIP.c */
#include "DoIP.h"
#include <string.h>

typedef enum
{
    DOIP_TCP_OFFLINE = 0,
    DOIP_TCP_CONNECTED,
    DOIP_TCP_ROUTING_ACTIVE
} DoIP_TcpStateType;

typedef struct
{
    const DoIP_ConfigType *cfg;
    DoIP_DcmRxIndicationFct dcmRxIndication;
    DoIP_TcpStateType tcpState;
    TcpIp_SockAddrType lastUdpRemote;
    uint16_t testerLogicalAddress;
    uint8_t rxBuffer[DOIP_HEADER_LEN + DOIP_MAX_UDS_PAYLOAD_LEN + 4u];
} DoIP_RuntimeType;

static DoIP_RuntimeType DoIP_Rt;

static uint16_t DoIP_ReadU16(const uint8_t *p)
{
    return (uint16_t)(((uint16_t)p[0] << 8u) | p[1]);
}

static uint32_t DoIP_ReadU32(const uint8_t *p)
{
    return ((uint32_t)p[0] << 24u) |
           ((uint32_t)p[1] << 16u) |
           ((uint32_t)p[2] << 8u) |
           ((uint32_t)p[3]);
}

static void DoIP_WriteU16(uint8_t *p, uint16_t v)
{
    p[0] = (uint8_t)((v >> 8u) & 0xFFu);
    p[1] = (uint8_t)(v & 0xFFu);
}

static void DoIP_WriteU32(uint8_t *p, uint32_t v)
{
    p[0] = (uint8_t)((v >> 24u) & 0xFFu);
    p[1] = (uint8_t)((v >> 16u) & 0xFFu);
    p[2] = (uint8_t)((v >> 8u) & 0xFFu);
    p[3] = (uint8_t)(v & 0xFFu);
}

static uint8_t DoIP_CheckHeader(const uint8_t *data, uint16_t len, uint16_t *payloadType, uint32_t *payloadLen)
{
    if ((data == 0) || (len < DOIP_HEADER_LEN))
    {
        return 0u;
    }

    if (data[0] != DOIP_PROTOCOL_VERSION)
    {
        return 0u;
    }

    if (data[1] != DOIP_INVERSE_PROTOCOL_VERSION)
    {
        return 0u;
    }

    *payloadType = DoIP_ReadU16(&data[2]);
    *payloadLen = DoIP_ReadU32(&data[4]);

    if ((DOIP_HEADER_LEN + *payloadLen) > len)
    {
        return 0u;
    }

    return 1u;
}

static uint16_t DoIP_MakeHeader(uint8_t *buf, uint16_t payloadType, uint32_t payloadLen)
{
    buf[0] = DOIP_PROTOCOL_VERSION;
    buf[1] = DOIP_INVERSE_PROTOCOL_VERSION;
    DoIP_WriteU16(&buf[2], payloadType);
    DoIP_WriteU32(&buf[4], payloadLen);
    return DOIP_HEADER_LEN;
}

static void DoIP_SendVehicleIdentificationResponse(const TcpIp_SockAddrType *remoteAddr)
{
    uint8_t tx[DOIP_HEADER_LEN + 32u];
    uint16_t idx;
    uint8_t i;

    idx = DoIP_MakeHeader(tx, DOIP_PAYLOAD_VEHICLE_ID_RES, 32u);

    for (i = 0u; i < DOIP_MAX_VIN_LEN; i++)
    {
        tx[idx++] = (uint8_t)DoIP_Rt.cfg->vin[i];
    }

    DoIP_WriteU16(&tx[idx], DoIP_Rt.cfg->logicalAddress);
    idx += 2u;

    for (i = 0u; i < DOIP_MAX_EID_LEN; i++)
    {
        tx[idx++] = DoIP_Rt.cfg->eid[i];
    }

    for (i = 0u; i < DOIP_MAX_GID_LEN; i++)
    {
        tx[idx++] = DoIP_Rt.cfg->gid[i];
    }

    tx[idx++] = 0x00u;

    (void)SoAd_IfTransmit(DoIP_Rt.cfg->udpSoConId, remoteAddr, tx, idx);
}

static void DoIP_SendRoutingActivationResponse(uint8_t responseCode)
{
    uint8_t tx[DOIP_HEADER_LEN + 9u];
    uint16_t idx;

    idx = DoIP_MakeHeader(tx, DOIP_PAYLOAD_ROUTING_ACTIVATION_RES, 9u);

    DoIP_WriteU16(&tx[idx], DoIP_Rt.testerLogicalAddress);
    idx += 2u;

    DoIP_WriteU16(&tx[idx], DoIP_Rt.cfg->logicalAddress);
    idx += 2u;

    tx[idx++] = responseCode;

    tx[idx++] = 0x00u;
    tx[idx++] = 0x00u;
    tx[idx++] = 0x00u;
    tx[idx++] = 0x00u;

    (void)SoAd_IfTransmit(DoIP_Rt.cfg->tcpSoConId, 0, tx, idx);
}

static void DoIP_SendAliveCheckResponse(void)
{
    uint8_t tx[DOIP_HEADER_LEN + 2u];
    uint16_t idx;

    idx = DoIP_MakeHeader(tx, DOIP_PAYLOAD_ALIVE_CHECK_RES, 2u);
    DoIP_WriteU16(&tx[idx], DoIP_Rt.cfg->logicalAddress);
    idx += 2u;

    (void)SoAd_IfTransmit(DoIP_Rt.cfg->tcpSoConId, 0, tx, idx);
}

static void DoIP_SendDiagPositiveAck(uint16_t sourceAddress, uint16_t targetAddress)
{
    uint8_t tx[DOIP_HEADER_LEN + 5u];
    uint16_t idx;

    idx = DoIP_MakeHeader(tx, DOIP_PAYLOAD_DIAG_MSG_POS_ACK, 5u);

    DoIP_WriteU16(&tx[idx], targetAddress);
    idx += 2u;

    DoIP_WriteU16(&tx[idx], sourceAddress);
    idx += 2u;

    tx[idx++] = 0x00u;

    (void)SoAd_IfTransmit(DoIP_Rt.cfg->tcpSoConId, 0, tx, idx);
}

static void DoIP_SendDiagNegativeAck(uint16_t sourceAddress, uint16_t targetAddress, uint8_t nack)
{
    uint8_t tx[DOIP_HEADER_LEN + 5u];
    uint16_t idx;

    idx = DoIP_MakeHeader(tx, DOIP_PAYLOAD_DIAG_MSG_NEG_ACK, 5u);

    DoIP_WriteU16(&tx[idx], targetAddress);
    idx += 2u;

    DoIP_WriteU16(&tx[idx], sourceAddress);
    idx += 2u;

    tx[idx++] = nack;

    (void)SoAd_IfTransmit(DoIP_Rt.cfg->tcpSoConId, 0, tx, idx);
}

static void DoIP_HandleUdp(const TcpIp_SockAddrType *remoteAddr,
                           const uint8_t *data,
                           uint16_t len)
{
    uint16_t payloadType;
    uint32_t payloadLen;

    if (DoIP_CheckHeader(data, len, &payloadType, &payloadLen) == 0u)
    {
        return;
    }

    if (payloadType == DOIP_PAYLOAD_VEHICLE_ID_REQ)
    {
        DoIP_Rt.lastUdpRemote = *remoteAddr;
        DoIP_SendVehicleIdentificationResponse(remoteAddr);
    }
}

static void DoIP_HandleRoutingActivation(const uint8_t *payload, uint32_t payloadLen)
{
    uint16_t sourceAddress;

    if (payloadLen < 7u)
    {
        return;
    }

    sourceAddress = DoIP_ReadU16(&payload[0]);

    DoIP_Rt.testerLogicalAddress = sourceAddress;
    DoIP_Rt.tcpState = DOIP_TCP_ROUTING_ACTIVE;

    DoIP_SendRoutingActivationResponse(0x10u);
}

static void DoIP_HandleDiagnosticMessage(const uint8_t *payload, uint32_t payloadLen)
{
    uint16_t sourceAddress;
    uint16_t targetAddress;
    const uint8_t *uds;
    uint16_t udsLen;

    if (payloadLen < 5u)
    {
        return;
    }

    sourceAddress = DoIP_ReadU16(&payload[0]);
    targetAddress = DoIP_ReadU16(&payload[2]);
    uds = &payload[4];
    udsLen = (uint16_t)(payloadLen - 4u);

    if (DoIP_Rt.tcpState != DOIP_TCP_ROUTING_ACTIVE)
    {
        DoIP_SendDiagNegativeAck(sourceAddress, targetAddress, DOIP_NACK_TRANSPORT_PROTOCOL_ERROR);
        return;
    }

    if (targetAddress != DoIP_Rt.cfg->logicalAddress)
    {
        DoIP_SendDiagNegativeAck(sourceAddress, targetAddress, DOIP_NACK_UNKNOWN_TARGET_ADDR);
        return;
    }

    if (udsLen > DOIP_MAX_UDS_PAYLOAD_LEN)
    {
        DoIP_SendDiagNegativeAck(sourceAddress, targetAddress, DOIP_NACK_DIAG_MSG_TOO_LARGE);
        return;
    }

    DoIP_SendDiagPositiveAck(sourceAddress, targetAddress);

    if (DoIP_Rt.dcmRxIndication != 0)
    {
        DoIP_Rt.dcmRxIndication(sourceAddress, targetAddress, uds, udsLen);
    }
}

static void DoIP_HandleTcp(const uint8_t *data, uint16_t len)
{
    uint16_t payloadType;
    uint32_t payloadLen;
    const uint8_t *payload;

    if (DoIP_CheckHeader(data, len, &payloadType, &payloadLen) == 0u)
    {
        return;
    }

    payload = &data[DOIP_HEADER_LEN];

    switch (payloadType)
    {
        case DOIP_PAYLOAD_ROUTING_ACTIVATION_REQ:
            DoIP_HandleRoutingActivation(payload, payloadLen);
            break;

        case DOIP_PAYLOAD_ALIVE_CHECK_REQ:
            DoIP_SendAliveCheckResponse();
            break;

        case DOIP_PAYLOAD_DIAG_MSG:
            DoIP_HandleDiagnosticMessage(payload, payloadLen);
            break;

        default:
            break;
    }
}

void DoIP_Init(const DoIP_ConfigType *config)
{
    memset(&DoIP_Rt, 0, sizeof(DoIP_Rt));
    DoIP_Rt.cfg = config;
    DoIP_Rt.tcpState = DOIP_TCP_OFFLINE;
    DoIP_Rt.testerLogicalAddress = 0x0E00u;
}

void DoIP_SetDcmRxIndication(DoIP_DcmRxIndicationFct cb)
{
    DoIP_Rt.dcmRxIndication = cb;
}

void DoIP_MainFunction(void)
{
}

void DoIP_SoAdUdpRxIndication(SoAd_SoConIdType soConId,
                              const TcpIp_SockAddrType *remoteAddr,
                              const uint8_t *data,
                              uint16_t len)
{
    (void)soConId;

    if ((DoIP_Rt.cfg == 0) || (remoteAddr == 0) || (data == 0))
    {
        return;
    }

    DoIP_HandleUdp(remoteAddr, data, len);
}

void DoIP_SoAdTcpRxIndication(SoAd_SoConIdType soConId,
                              const TcpIp_SockAddrType *remoteAddr,
                              const uint8_t *data,
                              uint16_t len)
{
    (void)soConId;
    (void)remoteAddr;

    if ((DoIP_Rt.cfg == 0) || (data == 0))
    {
        return;
    }

    DoIP_HandleTcp(data, len);
}

void DoIP_SoAdTcpConnected(SoAd_SoConIdType soConId)
{
    (void)soConId;
    DoIP_Rt.tcpState = DOIP_TCP_CONNECTED;
}

void DoIP_SoAdTcpDisconnected(SoAd_SoConIdType soConId)
{
    (void)soConId;
    DoIP_Rt.tcpState = DOIP_TCP_OFFLINE;
}

DoIP_ReturnType DoIP_SendDiagnosticResponse(uint16_t sourceAddress,
                                            uint16_t targetAddress,
                                            const uint8_t *uds,
                                            uint16_t udsLen)
{
    uint16_t idx;

    if ((DoIP_Rt.cfg == 0) || (uds == 0) || (udsLen > DOIP_MAX_UDS_PAYLOAD_LEN))
    {
        return DOIP_PARAM_ERROR;
    }

    if (DoIP_Rt.tcpState != DOIP_TCP_ROUTING_ACTIVE)
    {
        return DOIP_BUSY;
    }

    idx = DoIP_MakeHeader(DoIP_Rt.rxBuffer,
                          DOIP_PAYLOAD_DIAG_MSG,
                          (uint32_t)udsLen + 4u);

    DoIP_WriteU16(&DoIP_Rt.rxBuffer[idx], sourceAddress);
    idx += 2u;

    DoIP_WriteU16(&DoIP_Rt.rxBuffer[idx], targetAddress);
    idx += 2u;

    memcpy(&DoIP_Rt.rxBuffer[idx], uds, udsLen);
    idx += udsLen;

    if (SoAd_IfTransmit(DoIP_Rt.cfg->tcpSoConId, 0, DoIP_Rt.rxBuffer, idx) != SOAD_OK)
    {
        return DOIP_BUSY;
    }

    return DOIP_OK;
}
