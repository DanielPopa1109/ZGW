/* CanTp.c */
#include "CanTp.h"
#include "PduR.h"
#include <string.h>

typedef struct
{
    CanTp_StateType state;

    uint8 rxBuffer[CANTP_MAX_PAYLOAD_LEN];
    PduLengthType rxLen;
    PduLengthType rxExpectedLen;
    uint8 rxNextSn;

    uint8 txBuffer[CANTP_MAX_PAYLOAD_LEN];
    PduLengthType txLen;
    PduLengthType txOffset;
    uint8 txSn;
    uint8 txBlockCounter;
    uint8 txBlockSize;
    uint8 txStMinTicks;
    uint8 txStTimer;
    uint8 txCanIfPduBusy;

    uint8 rxCanIfPduBusy;
} CanTp_ChannelStateType;

static const CanTp_ChannelConfigType CanTp_ChannelConfig[] =
{
    { CANIF_PDU_CLASSIC_PHYS_RX, CANIF_PDU_CLASSIC_PHYS_TX, 0u, 0u, CANTP_ADDR_PHYSICAL,   8u,  0u, 0u },
    { CANIF_PDU_CLASSIC_FUNC_RX, CANIF_PDU_CLASSIC_PHYS_TX, 1u, 0u, CANTP_ADDR_FUNCTIONAL, 8u,  0u, 0u },
    { CANIF_PDU_FD_PHYS_RX,      CANIF_PDU_FD_PHYS_TX,      2u, 1u, CANTP_ADDR_PHYSICAL,   64u, 0u, 0u },
    { CANIF_PDU_FD_FUNC_RX,      CANIF_PDU_FD_PHYS_TX,      3u, 1u, CANTP_ADDR_FUNCTIONAL, 64u, 0u, 0u }
};

const CanTp_ConfigType CanTp_Config =
{
    CanTp_ChannelConfig,
    (uint8)(sizeof(CanTp_ChannelConfig) / sizeof(CanTp_ChannelConfig[0]))
};

static const CanTp_ConfigType* CanTp_ConfigPtr;
static CanTp_ChannelStateType CanTp_Channel[CANTP_MAX_CHANNELS];

static uint8 CanTp_FindRxChannel(PduIdType rxPduId)
{
    uint8 i;

    for (i = 0u; i < CanTp_ConfigPtr->numChannels; i++)
    {
        if (CanTp_ConfigPtr->channels[i].rxPduId == rxPduId)
        {
            return i;
        }
    }

    return 0xFFu;
}

static uint8 CanTp_FindTxChannelByUpper(PduIdType upperTxPduId)
{
    uint8 i;

    for (i = 0u; i < CanTp_ConfigPtr->numChannels; i++)
    {
        if (CanTp_ConfigPtr->channels[i].upperTxPduId == upperTxPduId)
        {
            return i;
        }
    }

    return 0xFFu;
}

static uint8 CanTp_FindTxChannelByCanIf(PduIdType txPduId)
{
    uint8 i;

    for (i = 0u; i < CanTp_ConfigPtr->numChannels; i++)
    {
        if (CanTp_ConfigPtr->channels[i].txPduId == txPduId)
        {
            return i;
        }
    }

    return 0xFFu;
}

void CanTp_Init(const CanTp_ConfigType* ConfigPtr)
{
    CanTp_ConfigPtr = (ConfigPtr == NULL_PTR) ? &CanTp_Config : ConfigPtr;
    memset(CanTp_Channel, 0, sizeof(CanTp_Channel));
}

static Std_ReturnType CanTp_SendFc(uint8 ch, uint8 fs)
{
    uint8 frame[8u];

    memset(frame, 0, sizeof(frame));
    frame[0] = (uint8)(CANTP_NPCI_FC | fs);
    frame[1] = CanTp_ConfigPtr->channels[ch].blockSize;
    frame[2] = CanTp_ConfigPtr->channels[ch].stMinTicks;

    return CanIf_Transmit(CanTp_ConfigPtr->channels[ch].txPduId, frame, 8u);
}

static Std_ReturnType CanTp_SendSingleFrame(uint8 ch)
{
    uint8 frame[64u];
    uint8 len;

    len = (uint8)CanTp_Channel[ch].txLen;
    memset(frame, 0, sizeof(frame));

    if (CanTp_ConfigPtr->channels[ch].canDl <= 8u)
    {
        frame[0] = len & 0x0Fu;
        memcpy(&frame[1], CanTp_Channel[ch].txBuffer, len);
        return CanIf_Transmit(CanTp_ConfigPtr->channels[ch].txPduId, frame, (PduLengthType)(len + 1u));
    }

    frame[0] = 0x00u;
    frame[1] = len;
    memcpy(&frame[2], CanTp_Channel[ch].txBuffer, len);
    return CanIf_Transmit(CanTp_ConfigPtr->channels[ch].txPduId, frame, CanTp_ConfigPtr->channels[ch].canDl);
}

static Std_ReturnType CanTp_SendFirstFrame(uint8 ch)
{
    uint8 frame[64u];
    uint8 payloadInFf;

    memset(frame, 0, sizeof(frame));

    frame[0] = (uint8)(CANTP_NPCI_FF | ((CanTp_Channel[ch].txLen >> 8u) & 0x0Fu));
    frame[1] = (uint8)(CanTp_Channel[ch].txLen & 0xFFu);

    payloadInFf = (uint8)(CanTp_ConfigPtr->channels[ch].canDl - 2u);

    memcpy(&frame[2], CanTp_Channel[ch].txBuffer, payloadInFf);

    CanTp_Channel[ch].txOffset = payloadInFf;
    CanTp_Channel[ch].txSn = 1u;
    CanTp_Channel[ch].state = CANTP_TX_WAIT_FC;
    CanTp_Channel[ch].txCanIfPduBusy = TRUE;

    return CanIf_Transmit(CanTp_ConfigPtr->channels[ch].txPduId, frame, CanTp_ConfigPtr->channels[ch].canDl);
}

static Std_ReturnType CanTp_SendConsecutiveFrame(uint8 ch)
{
    uint8 frame[64u];
    PduLengthType remaining;
    uint8 payload;
    uint8 copy;

    if (CanTp_Channel[ch].txCanIfPduBusy == TRUE)
    {
        return E_NOT_OK;
    }

    if (CanTp_Channel[ch].txStTimer > 0u)
    {
        return E_NOT_OK;
    }

    memset(frame, 0, sizeof(frame));

    frame[0] = (uint8)(CANTP_NPCI_CF | (CanTp_Channel[ch].txSn & 0x0Fu));

    remaining = (PduLengthType)(CanTp_Channel[ch].txLen - CanTp_Channel[ch].txOffset);
    payload = (uint8)(CanTp_ConfigPtr->channels[ch].canDl - 1u);
    copy = (remaining > payload) ? payload : (uint8)remaining;

    memcpy(&frame[1], &CanTp_Channel[ch].txBuffer[CanTp_Channel[ch].txOffset], copy);

    CanTp_Channel[ch].txOffset = (PduLengthType)(CanTp_Channel[ch].txOffset + copy);
    CanTp_Channel[ch].txSn = (uint8)((CanTp_Channel[ch].txSn + 1u) & 0x0Fu);
    CanTp_Channel[ch].txBlockCounter++;
    CanTp_Channel[ch].txCanIfPduBusy = TRUE;
    CanTp_Channel[ch].txStTimer = CanTp_Channel[ch].txStMinTicks;

    if (CanIf_Transmit(CanTp_ConfigPtr->channels[ch].txPduId, frame, CanTp_ConfigPtr->channels[ch].canDl) != E_OK)
    {
        CanTp_Channel[ch].txCanIfPduBusy = FALSE;
        return E_NOT_OK;
    }

    if (CanTp_Channel[ch].txOffset >= CanTp_Channel[ch].txLen)
    {
        CanTp_Channel[ch].state = CANTP_IDLE;
        PduR_CanTpTxConfirmation(CanTp_ConfigPtr->channels[ch].upperTxPduId, E_OK);
    }
    else if ((CanTp_Channel[ch].txBlockSize != 0u) &&
             (CanTp_Channel[ch].txBlockCounter >= CanTp_Channel[ch].txBlockSize))
    {
        CanTp_Channel[ch].state = CANTP_TX_WAIT_FC;
    }

    return E_OK;
}

Std_ReturnType CanTp_Transmit(PduIdType CanTpTxSduId, const uint8* data, PduLengthType len)
{
    uint8 ch;
    uint8 sfMax;

    if ((CanTp_ConfigPtr == NULL_PTR) || (data == NULL_PTR) || (len == 0u) || (len > CANTP_MAX_PAYLOAD_LEN))
    {
        return E_NOT_OK;
    }

    ch = CanTp_FindTxChannelByUpper(CanTpTxSduId);

    if (ch >= CanTp_ConfigPtr->numChannels)
    {
        return E_NOT_OK;
    }

    if (CanTp_Channel[ch].state != CANTP_IDLE)
    {
        return E_NOT_OK;
    }

    memcpy(CanTp_Channel[ch].txBuffer, data, len);
    CanTp_Channel[ch].txLen = len;
    CanTp_Channel[ch].txOffset = 0u;
    CanTp_Channel[ch].txBlockCounter = 0u;
    CanTp_Channel[ch].txBlockSize = 0u;
    CanTp_Channel[ch].txStMinTicks = 0u;
    CanTp_Channel[ch].txStTimer = 0u;
    CanTp_Channel[ch].txCanIfPduBusy = FALSE;

    sfMax = (CanTp_ConfigPtr->channels[ch].canDl <= 8u) ? 7u : 62u;

    if (len <= sfMax)
    {
        return CanTp_SendSingleFrame(ch);
    }

    return CanTp_SendFirstFrame(ch);
}

void CanTp_RxIndication(PduIdType CanIfRxPduId, const uint8* data, PduLengthType len)
{
    uint8 ch;
    uint8 pci;
    uint8 sfLen;
    PduLengthType totalLen;
    uint8 copy;
    uint8 payload;
    uint8 sn;

    if ((CanTp_ConfigPtr == NULL_PTR) || (data == NULL_PTR) || (len == 0u))
    {
        return;
    }

    ch = CanTp_FindRxChannel(CanIfRxPduId);

    if (ch >= CanTp_ConfigPtr->numChannels)
    {
        return;
    }

    pci = data[0] & 0xF0u;

    if (pci == CANTP_NPCI_SF)
    {
        if (CanTp_ConfigPtr->channels[ch].canDl <= 8u)
        {
            sfLen = data[0] & 0x0Fu;
            if ((sfLen == 0u) || ((PduLengthType)(sfLen + 1u) > len))
            {
                return;
            }

            memcpy(CanTp_Channel[ch].rxBuffer, &data[1], sfLen);
            PduR_CanTpRxIndication(CanTp_ConfigPtr->channels[ch].upperRxPduId, CanTp_Channel[ch].rxBuffer, sfLen);
            return;
        }

        if (len < 2u)
        {
            return;
        }

        sfLen = data[1];

        if ((sfLen == 0u) || ((PduLengthType)(sfLen + 2u) > len))
        {
            return;
        }

        memcpy(CanTp_Channel[ch].rxBuffer, &data[2], sfLen);
        PduR_CanTpRxIndication(CanTp_ConfigPtr->channels[ch].upperRxPduId, CanTp_Channel[ch].rxBuffer, sfLen);
        return;
    }

    if (pci == CANTP_NPCI_FF)
    {
        totalLen = (PduLengthType)((((PduLengthType)data[0] & 0x0Fu) << 8u) | data[1]);

        if ((totalLen == 0u) || (totalLen > CANTP_MAX_PAYLOAD_LEN))
        {
            (void)CanTp_SendFc(ch, CANTP_FS_OVFLW);
            return;
        }

        payload = (uint8)(len - 2u);
        copy = (totalLen > payload) ? payload : (uint8)totalLen;

        memcpy(CanTp_Channel[ch].rxBuffer, &data[2], copy);

        CanTp_Channel[ch].rxExpectedLen = totalLen;
        CanTp_Channel[ch].rxLen = copy;
        CanTp_Channel[ch].rxNextSn = 1u;
        CanTp_Channel[ch].state = CANTP_RX_IN_PROGRESS;

        (void)CanTp_SendFc(ch, CANTP_FS_CTS);
        return;
    }

    if (pci == CANTP_NPCI_CF)
    {
        if (CanTp_Channel[ch].state != CANTP_RX_IN_PROGRESS)
        {
            return;
        }

        sn = data[0] & 0x0Fu;

        if (sn != CanTp_Channel[ch].rxNextSn)
        {
            CanTp_Channel[ch].state = CANTP_IDLE;
            return;
        }

        payload = (uint8)(len - 1u);
        totalLen = (PduLengthType)(CanTp_Channel[ch].rxExpectedLen - CanTp_Channel[ch].rxLen);
        copy = (totalLen > payload) ? payload : (uint8)totalLen;

        memcpy(&CanTp_Channel[ch].rxBuffer[CanTp_Channel[ch].rxLen], &data[1], copy);

        CanTp_Channel[ch].rxLen = (PduLengthType)(CanTp_Channel[ch].rxLen + copy);
        CanTp_Channel[ch].rxNextSn = (uint8)((CanTp_Channel[ch].rxNextSn + 1u) & 0x0Fu);

        if (CanTp_Channel[ch].rxLen >= CanTp_Channel[ch].rxExpectedLen)
        {
            PduR_CanTpRxIndication(
                CanTp_ConfigPtr->channels[ch].upperRxPduId,
                CanTp_Channel[ch].rxBuffer,
                CanTp_Channel[ch].rxExpectedLen
            );

            CanTp_Channel[ch].state = CANTP_IDLE;
        }

        return;
    }

    if (pci == CANTP_NPCI_FC)
    {
        if (CanTp_Channel[ch].state != CANTP_TX_WAIT_FC)
        {
            return;
        }

        if ((data[0] & 0x0Fu) == CANTP_FS_CTS)
        {
            CanTp_Channel[ch].txBlockSize = data[1];
            CanTp_Channel[ch].txStMinTicks = data[2];
            CanTp_Channel[ch].txBlockCounter = 0u;
            CanTp_Channel[ch].state = CANTP_TX_CF;
        }
        else if ((data[0] & 0x0Fu) == CANTP_FS_OVFLW)
        {
            CanTp_Channel[ch].state = CANTP_IDLE;
            PduR_CanTpTxConfirmation(CanTp_ConfigPtr->channels[ch].upperTxPduId, E_NOT_OK);
        }
    }
}

void CanTp_TxConfirmation(PduIdType CanIfTxPduId)
{
    uint8 ch;

    if (CanTp_ConfigPtr == NULL_PTR)
    {
        return;
    }

    ch = CanTp_FindTxChannelByCanIf(CanIfTxPduId);

    if (ch >= CanTp_ConfigPtr->numChannels)
    {
        return;
    }

    CanTp_Channel[ch].txCanIfPduBusy = FALSE;
}

void CanTp_MainFunction(void)
{
    uint8 ch;

    if (CanTp_ConfigPtr == NULL_PTR)
    {
        return;
    }

    for (ch = 0u; ch < CanTp_ConfigPtr->numChannels; ch++)
    {
        if (CanTp_Channel[ch].txStTimer > 0u)
        {
            CanTp_Channel[ch].txStTimer--;
        }

        if (CanTp_Channel[ch].state == CANTP_TX_CF)
        {
            (void)CanTp_SendConsecutiveFrame(ch);
        }
    }
}
