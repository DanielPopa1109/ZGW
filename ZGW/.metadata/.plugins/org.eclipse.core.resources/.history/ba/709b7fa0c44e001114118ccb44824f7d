static void Os_InitFailure(uint8 CoreId, uint32 Step)
{
    Os_FreeRtosInitFailureCore = CoreId;
    Os_FreeRtosInitFailureStep = Step;

    McuSm_PerformResetHook(381u, (((uint32)CoreId) << 16u) | Step);

    for(;;)
    {
        /* Wait for reset. */
    }
}

