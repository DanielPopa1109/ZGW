/* FblEth_AurixLwip.c
 * Strong implementation of FblEth_* hooks for AURIX TC375 + GETH + lwIP NO_SYS raw API.
 *
 * Intended project setup:
 *  - AURIX Development Studio / TASKING
 *  - iLLD 4.0.4
 *  - Infineon Ethernet_1_KIT_TC375_LK / ACS-generated lwIP GETH port
 *  - NO_SYS = 1
 *  - LWIP_RAW = 1
 *  - LWIP_TCP = 1
 *  - LWIP_UDP = 1
 *  - LWIP_DHCP = 1 or 0
 *
 * This file overrides the weak hooks from Cpu0_Main_AURIX_FBL.c:
 *   FblEth_Init
 *   FblEth_MainFunction
 *   FblEth_TcpReceive
 *   FblEth_UdpReceive
 *   FblEth_TcpSend
 *   FblEth_UdpSend
 *
 * DoIP:
 *   TCP port 13400: diagnostic message transport
 *   UDP port 13400: vehicle identification discovery
 */

#include <string.h>
#include "Ifx_Types.h"

#include "lwip/init.h"
#include "lwip/netif.h"
#include "lwip/ip4_addr.h"
#include "lwip/tcp.h"
#include "lwip/udp.h"
#include "lwip/pbuf.h"
#include "lwip/timeouts.h"
#include "lwip/dhcp.h"
#include "lwip/etharp.h"

/* Infineon lwIP/GETH port header from Ethernet_1_KIT_TC375_LK or ACS generation. */
#include "lwip_geth.h"

#ifndef DOIP_TCP_PORT
#define DOIP_TCP_PORT                         13400u
#endif

#ifndef DOIP_UDP_PORT
#define DOIP_UDP_PORT                         13400u
#endif

#ifndef FBL_ETH_RX_BUF_SIZE
#define FBL_ETH_RX_BUF_SIZE                   2048u
#endif

#ifndef FBL_ETH_USE_DHCP
#define FBL_ETH_USE_DHCP                      1u
#endif

#ifndef FBL_ETH_STATIC_IP0
#define FBL_ETH_STATIC_IP0                    192u
#define FBL_ETH_STATIC_IP1                    168u
#define FBL_ETH_STATIC_IP2                    1u
#define FBL_ETH_STATIC_IP3                    88u
#endif

#ifndef FBL_ETH_NETMASK0
#define FBL_ETH_NETMASK0                      255u
#define FBL_ETH_NETMASK1                      255u
#define FBL_ETH_NETMASK2                      255u
#define FBL_ETH_NETMASK3                      0u
#endif

#ifndef FBL_ETH_GATEWAY0
#define FBL_ETH_GATEWAY0                      192u
#define FBL_ETH_GATEWAY1                      168u
#define FBL_ETH_GATEWAY2                      1u
#define FBL_ETH_GATEWAY3                      1u
#endif

/* Most Infineon lwIP/GETH NO_SYS ports expose ethernetif_input(struct netif *).
 * If your ACS generated function has a different name, define this macro in project symbols.
 */
#ifndef FBL_ETHERNETIF_INPUT_FUNC
#define FBL_ETHERNETIF_INPUT_FUNC             ethernetif_input
#endif

/* Some generated ports require a low-level periodic service call. Leave empty by default.
 * If your project has one, define e.g. FBL_ETHERNETIF_POLL_FUNC=Ifx_Lwip_pollTimer.
 */
#ifndef FBL_ETHERNETIF_POLL_FUNC
#define FBL_ETHERNETIF_POLL_FUNC()            do { } while(0)
#endif

extern err_t ethernetif_init(struct netif *netif);
extern void FBL_ETHERNETIF_INPUT_FUNC(struct netif *netif);

static struct netif g_fblEthNetif;
static struct tcp_pcb *g_fblTcpListenPcb;
static struct tcp_pcb *g_fblTcpActivePcb;
static struct udp_pcb *g_fblUdpPcb;

static uint8 g_fblTcpRxBuf[FBL_ETH_RX_BUF_SIZE];
static uint16 g_fblTcpRxLen;
static volatile uint8 g_fblTcpRxPending;

static uint8 g_fblUdpRxBuf[FBL_ETH_RX_BUF_SIZE];
static uint16 g_fblUdpRxLen;
static volatile uint8 g_fblUdpRxPending;
static ip_addr_t g_fblUdpRemoteIp;
static uint16 g_fblUdpRemotePort;
static uint8 g_fblUdpRemoteValid;

static uint8 g_fblEthInitialized;

static void FblEth_CopyFromPbuf(uint8 *dst, uint16 *dstLen, const struct pbuf *p)
{
    uint16 copied = 0u;
    const struct pbuf *q;

    for(q = p; q != NULL; q = q->next)
    {
        uint16 chunkLen = q->len;

        if((copied + chunkLen) > FBL_ETH_RX_BUF_SIZE)
        {
            chunkLen = (uint16)(FBL_ETH_RX_BUF_SIZE - copied);
        }

        if(chunkLen > 0u)
        {
            memcpy(&dst[copied], q->payload, chunkLen);
            copied = (uint16)(copied + chunkLen);
        }

        if(copied >= FBL_ETH_RX_BUF_SIZE)
        {
            break;
        }
    }

    *dstLen = copied;
}

static err_t FblEth_TcpRecvCb(void *arg, struct tcp_pcb *tpcb, struct pbuf *p, err_t err)
{
    (void)arg;

    if((err != ERR_OK) || (tpcb == NULL))
    {
        if(p != NULL)
        {
            pbuf_free(p);
        }
        return ERR_OK;
    }

    if(p == NULL)
    {
        if(g_fblTcpActivePcb == tpcb)
        {
            g_fblTcpActivePcb = NULL;
        }
        tcp_arg(tpcb, NULL);
        tcp_recv(tpcb, NULL);
        tcp_err(tpcb, NULL);
        tcp_close(tpcb);
        return ERR_OK;
    }

    FblEth_CopyFromPbuf(g_fblTcpRxBuf, &g_fblTcpRxLen, p);
    g_fblTcpRxPending = 1u;

    tcp_recved(tpcb, p->tot_len);
    pbuf_free(p);

    return ERR_OK;
}

static void FblEth_TcpErrCb(void *arg, err_t err)
{
    (void)arg;
    (void)err;
    g_fblTcpActivePcb = NULL;
}

static err_t FblEth_TcpAcceptCb(void *arg, struct tcp_pcb *newpcb, err_t err)
{
    (void)arg;

    if((err != ERR_OK) || (newpcb == NULL))
    {
        return ERR_VAL;
    }

    if(g_fblTcpActivePcb != NULL)
    {
        tcp_abort(newpcb);
        return ERR_ABRT;
    }

    g_fblTcpActivePcb = newpcb;
    tcp_setprio(newpcb, TCP_PRIO_NORMAL);
    tcp_arg(newpcb, NULL);
    tcp_recv(newpcb, FblEth_TcpRecvCb);
    tcp_err(newpcb, FblEth_TcpErrCb);

    return ERR_OK;
}

static void FblEth_UdpRecvCb(void *arg,
                             struct udp_pcb *upcb,
                             struct pbuf *p,
                             const ip_addr_t *addr,
                             u16_t port)
{
    (void)arg;
    (void)upcb;

    if((p == NULL) || (addr == NULL))
    {
        return;
    }

    FblEth_CopyFromPbuf(g_fblUdpRxBuf, &g_fblUdpRxLen, p);
    ip_addr_copy(g_fblUdpRemoteIp, *addr);
    g_fblUdpRemotePort = port;
    g_fblUdpRemoteValid = 1u;
    g_fblUdpRxPending = 1u;

    pbuf_free(p);
}

static void FblEth_StartTcpServer(void)
{
    err_t err;

    g_fblTcpListenPcb = tcp_new_ip_type(IPADDR_TYPE_ANY);
    if(g_fblTcpListenPcb == NULL)
    {
        return;
    }

    err = tcp_bind(g_fblTcpListenPcb, IP_ANY_TYPE, DOIP_TCP_PORT);
    if(err != ERR_OK)
    {
        tcp_close(g_fblTcpListenPcb);
        g_fblTcpListenPcb = NULL;
        return;
    }

    g_fblTcpListenPcb = tcp_listen(g_fblTcpListenPcb);
    if(g_fblTcpListenPcb == NULL)
    {
        return;
    }

    tcp_accept(g_fblTcpListenPcb, FblEth_TcpAcceptCb);
}

static void FblEth_StartUdpServer(void)
{
    err_t err;

    g_fblUdpPcb = udp_new_ip_type(IPADDR_TYPE_ANY);
    if(g_fblUdpPcb == NULL)
    {
        return;
    }

    err = udp_bind(g_fblUdpPcb, IP_ANY_TYPE, DOIP_UDP_PORT);
    if(err != ERR_OK)
    {
        udp_remove(g_fblUdpPcb);
        g_fblUdpPcb = NULL;
        return;
    }

    udp_recv(g_fblUdpPcb, FblEth_UdpRecvCb, NULL);
}

void FblEth_Init(void)
{
    ip4_addr_t ipaddr;
    ip4_addr_t netmask;
    ip4_addr_t gw;

    if(g_fblEthInitialized != 0u)
    {
        return;
    }

    lwip_init();

#if (FBL_ETH_USE_DHCP != 0u)
    ip4_addr_set_zero(&ipaddr);
    ip4_addr_set_zero(&netmask);
    ip4_addr_set_zero(&gw);
#else
    IP4_ADDR(&ipaddr, FBL_ETH_STATIC_IP0, FBL_ETH_STATIC_IP1, FBL_ETH_STATIC_IP2, FBL_ETH_STATIC_IP3);
    IP4_ADDR(&netmask, FBL_ETH_NETMASK0, FBL_ETH_NETMASK1, FBL_ETH_NETMASK2, FBL_ETH_NETMASK3);
    IP4_ADDR(&gw, FBL_ETH_GATEWAY0, FBL_ETH_GATEWAY1, FBL_ETH_GATEWAY2, FBL_ETH_GATEWAY3);
#endif

    if(netif_add(&g_fblEthNetif, &ipaddr, &netmask, &gw, NULL, ethernetif_init, netif_input) == NULL)
    {
        return;
    }

    netif_set_default(&g_fblEthNetif);
    netif_set_up(&g_fblEthNetif);

#if (FBL_ETH_USE_DHCP != 0u)
    (void)dhcp_start(&g_fblEthNetif);
#endif

    FblEth_StartTcpServer();
    FblEth_StartUdpServer();

    g_fblEthInitialized = 1u;
}

void FblEth_MainFunction(void)
{
    if(g_fblEthInitialized == 0u)
    {
        return;
    }

    FBL_ETHERNETIF_INPUT_FUNC(&g_fblEthNetif);
    FBL_ETHERNETIF_POLL_FUNC();
    sys_check_timeouts();
}

uint8 FblEth_TcpReceive(uint8 *buf, uint16 *len)
{
    if((buf == NULL) || (len == NULL))
    {
        return 0u;
    }

    if(g_fblTcpRxPending == 0u)
    {
        return 0u;
    }

    memcpy(buf, g_fblTcpRxBuf, g_fblTcpRxLen);
    *len = g_fblTcpRxLen;
    g_fblTcpRxLen = 0u;
    g_fblTcpRxPending = 0u;

    return 1u;
}

uint8 FblEth_UdpReceive(uint8 *buf, uint16 *len)
{
    if((buf == NULL) || (len == NULL))
    {
        return 0u;
    }

    if(g_fblUdpRxPending == 0u)
    {
        return 0u;
    }

    memcpy(buf, g_fblUdpRxBuf, g_fblUdpRxLen);
    *len = g_fblUdpRxLen;
    g_fblUdpRxLen = 0u;
    g_fblUdpRxPending = 0u;

    return 1u;
}

void FblEth_TcpSend(const uint8 *buf, uint16 len)
{
    err_t err;

    if((g_fblTcpActivePcb == NULL) || (buf == NULL) || (len == 0u))
    {
        return;
    }

    if(tcp_sndbuf(g_fblTcpActivePcb) < len)
    {
        return;
    }

    err = tcp_write(g_fblTcpActivePcb, buf, len, TCP_WRITE_FLAG_COPY);
    if(err == ERR_OK)
    {
        (void)tcp_output(g_fblTcpActivePcb);
    }
}

void FblEth_UdpSend(const uint8 *buf, uint16 len)
{
    struct pbuf *p;
    err_t err;

    if((g_fblUdpPcb == NULL) || (buf == NULL) || (len == 0u))
    {
        return;
    }

    p = pbuf_alloc(PBUF_TRANSPORT, len, PBUF_RAM);
    if(p == NULL)
    {
        return;
    }

    memcpy(p->payload, buf, len);

    if(g_fblUdpRemoteValid != 0u)
    {
        err = udp_sendto(g_fblUdpPcb, p, &g_fblUdpRemoteIp, g_fblUdpRemotePort);
    }
    else
    {
        ip_addr_t broadcastIp;
        ip_addr_set_ip4_u32(&broadcastIp, PP_HTONL(IPADDR_BROADCAST));
        err = udp_sendto(g_fblUdpPcb, p, &broadcastIp, DOIP_UDP_PORT);
    }

    (void)err;
    pbuf_free(p);
}
