#include "TcpIpH.h"
#include "lwip_geth_private_phy_dp83825i.h"

#define TCPIP_MAX_SOCKETS 16

typedef struct
{
    int sock;
    uint8_t used;
    uint8_t tcp;
} TcpIp_SocketType;

static TcpIp_SocketType TcpIp_Sockets[TCPIP_MAX_SOCKETS];

static uint8_t TcpIp_IsLinkUp(void)
{
#if (PHY_DEVICE_NAME == PHY_DP83825I)
    return (uint8_t)lwip_geth_private_Phy_Dp83825i_is_link_up();
#else
    return 1u;
#endif
}

void TcpIp_Init(void)
{
    for (uint32_t i = 0; i < TCPIP_MAX_SOCKETS; i++)
    {
        TcpIp_Sockets[i].sock = TCPIP_INVALID_SOCKET;
        TcpIp_Sockets[i].used = 0u;
    }
}

void TcpIp_MainFunction(void)
{
    if (TcpIp_IsLinkUp() == 0u)
    {
        for (uint32_t i = 0; i < TCPIP_MAX_SOCKETS; i++)
        {
            if (TcpIp_Sockets[i].used != 0u)
            {
                lwip_close(TcpIp_Sockets[i].sock);
                TcpIp_Sockets[i].used = 0u;
            }
        }
    }
}

static TcpIp_SocketType* TcpIp_Alloc(void)
{
    for (uint32_t i = 0; i < TCPIP_MAX_SOCKETS; i++)
    {
        if (TcpIp_Sockets[i].used == 0u)
        {
            TcpIp_Sockets[i].used = 1u;
            return &TcpIp_Sockets[i];
        }
    }
    return NULL;
}

TcpIp_SocketIdType TcpIp_Create(uint8_t tcp)
{
    TcpIp_SocketType *s = TcpIp_Alloc();
    if (s == NULL)
    {
        return TCPIP_INVALID_SOCKET;
    }

    int type = tcp ? SOCK_STREAM : SOCK_DGRAM;

    s->sock = lwip_socket(AF_INET, type, 0);
    if (s->sock < 0)
    {
        s->used = 0u;
        return TCPIP_INVALID_SOCKET;
    }

    s->tcp = tcp;

    lwip_fcntl(s->sock, F_SETFL, O_NONBLOCK);

    return s->sock;
}

int32_t TcpIp_Bind(TcpIp_SocketIdType sock, uint16_t port)
{
    struct sockaddr_in addr;

    addr.sin_family = AF_INET;
    addr.sin_port = htons(port);
    addr.sin_addr.s_addr = INADDR_ANY;

    return lwip_bind(sock, (struct sockaddr*)&addr, sizeof(addr));
}

int32_t TcpIp_Listen(TcpIp_SocketIdType sock)
{
    return lwip_listen(sock, 4);
}

TcpIp_SocketIdType TcpIp_Accept(TcpIp_SocketIdType sock)
{
    struct sockaddr_in addr;
    socklen_t len = sizeof(addr);

    int newSock = lwip_accept(sock, (struct sockaddr*)&addr, &len);

    if (newSock >= 0)
    {
        lwip_fcntl(newSock, F_SETFL, O_NONBLOCK);
    }

    return newSock;
}

int32_t TcpIp_Connect(TcpIp_SocketIdType sock, uint32_t ip, uint16_t port)
{
    struct sockaddr_in addr;

    addr.sin_family = AF_INET;
    addr.sin_port = htons(port);
    addr.sin_addr.s_addr = ip;

    return lwip_connect(sock, (struct sockaddr*)&addr, sizeof(addr));
}

int32_t TcpIp_Send(TcpIp_SocketIdType sock, const uint8_t *data, uint16_t len)
{
    if (TcpIp_IsLinkUp() == 0u)
    {
        return -1;
    }

    return lwip_send(sock, data, len, 0);
}

int32_t TcpIp_Recv(TcpIp_SocketIdType sock, uint8_t *data, uint16_t len)
{
    return lwip_recv(sock, data, len, 0);
}

void TcpIp_Close(TcpIp_SocketIdType sock)
{
    lwip_close(sock);
}
