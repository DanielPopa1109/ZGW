#include "Lin.h"
#include "LinIf.h"
#include <string.h>


typedef struct
{
    Lin_StatusType status;
    Lin_PduType activePdu;
    uint8 rxData[LIN_MAX_FRAME_DATA_LEN + 1u];
    uint8 rxLen;
    uint8 rxIndex;
    uint8 txFrame[LIN_MAX_FRAME_DATA_LEN + 4u];
    uint8 txLen;
    uint8 txIndex;
    uint8 lastRxSdu[LIN_MAX_FRAME_DATA_LEN];
} Lin_ChannelStateType;

static const Lin_ConfigType* Lin_ConfigPtr = NULL_PTR;
static Lin_ChannelStateType Lin_State[LIN_MAX_CHANNELS];

static uint8 Lin_MakePid(uint8 id)
{
    uint8 p0;
    uint8 p1;
    uint8 pid;

    id &= 0x3Fu;

    p0 = (uint8)(((id >> 0u) ^ (id >> 1u) ^ (id >> 2u) ^ (id >> 4u)) & 0x01u);
    p1 = (uint8)((~((id >> 1u) ^ (id >> 3u) ^ (id >> 4u) ^ (id >> 5u))) & 0x01u);

    pid = (uint8)(id | (uint8)(p0 << 6u) | (uint8)(p1 << 7u));

    return pid;
}

static uint8 Lin_Checksum(uint8 pid, const uint8* data, uint8 len, Lin_ChecksumType type)
{
    uint16 sum = 0u;
    uint8 i;

    if (type == LIN_CS_ENHANCED)
    {
        sum += pid;
    }

    for (i = 0u; i < len; i++)
    {
        sum += data[i];

        if (sum > 255u)
        {
            sum = (uint16)((sum & 0xFFu) + 1u);
        }
    }

    return (uint8)(~sum);
}

static void Lin_AsclinInit(Lin_ChannelType Channel)
{
    IfxAsclin_Asc_Config ascConfig;
    IfxAsclin_Asc asclin;

    (void)Channel;

    IfxAsclin_Asc_initModuleConfig(&ascConfig, &LIN_ASCLIN_MODULE);

    ascConfig.baudrate.baudrate = LIN_DEFAULT_BAUDRATE;
    ascConfig.baudrate.oversampling = IfxAsclin_OversamplingFactor_16;

    ascConfig.bitTiming.medianFilter = IfxAsclin_SamplesPerBit_three;
    ascConfig.bitTiming.samplePointPosition = IfxAsclin_SamplePointPosition_8;

    ascConfig.frame.dataLength = IfxAsclin_DataLength_8;
    ascConfig.frame.parityBit = FALSE;
    ascConfig.frame.stopBit = IfxAsclin_StopBit_1;

    ascConfig.interrupt.txPriority = 0u;
    ascConfig.interrupt.rxPriority = 0u;
    ascConfig.interrupt.erPriority = 0u;

    ascConfig.pins.tx = &LIN_TX_PIN;
    ascConfig.pins.txMode = LIN_TX_PIN_MODE;
    ascConfig.pins.rx = &LIN_RX_PIN;
    ascConfig.pins.rxMode = LIN_RX_PIN_MODE;
    ascConfig.pins.pinDriver = LIN_PIN_PAD_DRIVER;

    IfxAsclin_Asc_initModule(&asclin, &ascConfig);
}

static Std_ReturnType Lin_AsclinWriteByte(Lin_ChannelType Channel, uint8 data)
{
    (void)Channel;

    IfxAsclin_write8(&LIN_ASCLIN_MODULE, data);

    return E_OK;
}

static boolean Lin_AsclinReadByte(Lin_ChannelType Channel, uint8* data)
{
    (void)Channel;

    if (IfxAsclin_getRxFifoFillLevel(&LIN_ASCLIN_MODULE) > 0u)
    {
        *data = IfxAsclin_read8(&LIN_ASCLIN_MODULE);
        return TRUE;
    }

    return FALSE;
}

void Lin_Init(const Lin_ConfigType* ConfigPtr)
{
    uint8 ch;

    Lin_ConfigPtr = ConfigPtr;

    for (ch = 0u; ch < LIN_MAX_CHANNELS; ch++)
    {
        memset(&Lin_State[ch], 0, sizeof(Lin_State[ch]));
        Lin_State[ch].status = LIN_INIT;
        Lin_AsclinInit(ch);
        Lin_State[ch].status = LIN_OPERATIONAL;
    }
}

Std_ReturnType Lin_SendFrame(Lin_ChannelType Channel, const Lin_PduType* PduInfoPtr)
{
    Lin_ChannelStateType* st;
    uint8 pid;
    uint8 checksum;
    uint8 i;

    if ((Lin_ConfigPtr == NULL_PTR) || (PduInfoPtr == NULL_PTR) || (Channel >= LIN_MAX_CHANNELS))
    {
        return E_NOT_OK;
    }

    st = &Lin_State[Channel];

    if ((st->status == LIN_TX_BUSY) || (st->status == LIN_RX_BUSY) || (PduInfoPtr->dlc > LIN_MAX_FRAME_DATA_LEN))
    {
        return E_NOT_OK;
    }

    pid = Lin_MakePid(PduInfoPtr->id);

    st->activePdu = *PduInfoPtr;
    st->txIndex = 0u;
    st->txLen = 0u;

    /* Break generation is hardware-dependent. This simplified variant sends sync + PID.
       Configure ASCLIN LIN break generation later if your iLLD setup exposes it directly. */

    st->txFrame[st->txLen++] = 0x55u;
    st->txFrame[st->txLen++] = pid;

    if (PduInfoPtr->responseType == LIN_FRAMERESPONSE_TX)
    {
        for (i = 0u; i < PduInfoPtr->dlc; i++)
        {
            st->txFrame[st->txLen++] = PduInfoPtr->data[i];
        }

        checksum = Lin_Checksum(pid, PduInfoPtr->data, PduInfoPtr->dlc, PduInfoPtr->checksumType);
        st->txFrame[st->txLen++] = checksum;
        st->status = LIN_TX_BUSY;
    }
    else if (PduInfoPtr->responseType == LIN_FRAMERESPONSE_RX)
    {
        st->rxIndex = 0u;
        st->rxLen = (uint8)(PduInfoPtr->dlc + 1u);
        st->status = LIN_RX_BUSY;
    }
    else
    {
        st->status = LIN_TX_BUSY;
    }

    (void)Lin_AsclinWriteByte(Channel, st->txFrame[st->txIndex++]);

    return E_OK;
}

Std_ReturnType Lin_GoToSleep(Lin_ChannelType Channel)
{
    if (Channel >= LIN_MAX_CHANNELS)
    {
        return E_NOT_OK;
    }

    Lin_State[Channel].status = LIN_SLEEP;
    return E_OK;
}

Std_ReturnType Lin_Wakeup(Lin_ChannelType Channel)
{
    if (Channel >= LIN_MAX_CHANNELS)
    {
        return E_NOT_OK;
    }

    Lin_State[Channel].status = LIN_OPERATIONAL;
    return E_OK;
}

Lin_StatusType Lin_GetStatus(Lin_ChannelType Channel, uint8* LinSduPtr)
{
    if (Channel >= LIN_MAX_CHANNELS)
    {
        return LIN_ERROR;
    }

    if (LinSduPtr != NULL_PTR)
    {
        memcpy(LinSduPtr, Lin_State[Channel].lastRxSdu, LIN_MAX_FRAME_DATA_LEN);
    }

    return Lin_State[Channel].status;
}

void Lin_TxIsr(Lin_ChannelType Channel)
{
    Lin_ChannelStateType* st;

    if (Channel >= LIN_MAX_CHANNELS)
    {
        return;
    }

    st = &Lin_State[Channel];

    if (st->status != LIN_TX_BUSY)
    {
        return;
    }

    if (st->txIndex < st->txLen)
    {
        (void)Lin_AsclinWriteByte(Channel, st->txFrame[st->txIndex++]);
    }
    else
    {
        st->status = LIN_OPERATIONAL;
        LinIf_TxConfirmation(Channel, st->activePdu.id);
    }
}

void Lin_RxIsr(Lin_ChannelType Channel)
{
    Lin_ChannelStateType* st;
    uint8 byte;
    uint8 pid;
    uint8 chk;

    if (Channel >= LIN_MAX_CHANNELS)
    {
        return;
    }

    st = &Lin_State[Channel];

    if (Lin_AsclinReadByte(Channel, &byte) == FALSE)
    {
        return;
    }

    if (st->status == LIN_TX_BUSY)
    {
        Lin_TxIsr(Channel);
        return;
    }

    if (st->status != LIN_RX_BUSY)
    {
        return;
    }

    if (st->rxIndex < st->rxLen)
    {
        st->rxData[st->rxIndex++] = byte;
    }

    if (st->rxIndex >= st->rxLen)
    {
        pid = Lin_MakePid(st->activePdu.id);
        chk = Lin_Checksum(pid, st->rxData, st->activePdu.dlc, st->activePdu.checksumType);

        if (chk == st->rxData[st->activePdu.dlc])
        {
            memcpy(st->lastRxSdu, st->rxData, st->activePdu.dlc);
            st->status = LIN_OPERATIONAL;
            LinIf_RxIndication(Channel, st->activePdu.id, st->rxData, st->activePdu.dlc);
        }
        else
        {
            st->status = LIN_ERROR;
            LinIf_ErrorIndication(Channel, st->activePdu.id);
        }
    }
}

void Lin_ErrIsr(Lin_ChannelType Channel)
{
    if (Channel < LIN_MAX_CHANNELS)
    {
        Lin_State[Channel].status = LIN_ERROR;
        LinIf_ErrorIndication(Channel, Lin_State[Channel].activePdu.id);
    }
}

void Lin_MainFunction(void)
{
    /* Low-level LIN driver is interrupt-driven.
       Timeout handling can be added here if needed. */
}

static const Lin_ChannelConfigType Lin_ChannelConfig[LIN_MAX_CHANNELS] =
{
    { &LIN_ASCLIN_MODULE, LIN_DEFAULT_BAUDRATE }
};

const Lin_ConfigType Lin_Config =
{
    Lin_ChannelConfig,
    LIN_MAX_CHANNELS
};
