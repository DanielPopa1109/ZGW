    Can_Hw.filter.id2 = 0x7E0u;
    IfxCan_Can_setStandardFilter(&Can_Hw.nodeFd, &Can_Hw.filter);
}

Std_ReturnType Can_SetControllerMode(uint8 Controller, Can_ControllerStateType Transition)
{
    if (Controller >= CAN_NUM_CONTROLLERS)
    {
        return E_NOT_OK;
    }

    switch (Transition)
    {
        case CAN_READY:
            Can_State = CAN_READY;
            return E_OK;

        case CAN_SLEEP:
            Can_State = CAN_SLEEP;
            return E_OK;

        case CAN_INIT:
            Can_State = CAN_INIT;
            return E_OK;

        default:
            return E_NOT_OK;
    }
}

void Can_Init(void)
{
    memset(&Can_Hw, 0, sizeof(Can_Hw));
    memset(Can_TxQueue, 0, sizeof(Can_TxQueue));
    memset(Can_RxQueue, 0, sizeof(Can_RxQueue));

    IfxScuCcu_setMcanFrequency(80000000.0f);

    IfxCan_Can_initModuleConfig(&Can_Hw.moduleConfig, &MODULE_CAN0);
    IfxCan_Can_initModule(&Can_Hw.module, &Can_Hw.moduleConfig);

    Can_InitClassicNode();
    Can_InitFdNode();

    Can_ControllerState[CAN_CONTROLLER_CLASSIC] = CAN_READY;
    Can_ControllerState[CAN_CONTROLLER_FD] = CAN_READY;
}

Std_ReturnType Can_Write(PduIdType Hth, const Can_PduType* PduInfo)
{
    (void)Hth;
    return Can_TxQueuePush(PduInfo);
}

static void Can_ProcessTx(void)
{
    Can_PduType pdu;
    IfxCan_Can_Node* node;
    uint8 data[CAN_MAX_DLC];

    if (Can_TxQueuePop(&pdu) != E_OK)
    {
        return;
    }

    if (pdu.controllerId >= CAN_NUM_CONTROLLERS)
    {
        return;
    }

    if (Can_ControllerState[pdu.controllerId] != CAN_READY)
    {
        return;
    }

    node = (pdu.controllerId == CAN_CONTROLLER_CLASSIC) ? &Can_Hw.nodeClassic : &Can_Hw.nodeFd;

    memset(data, 0, sizeof(data));
    memcpy(data, pdu.sdu, pdu.dlc);

    IfxCan_Can_initMessage(&Can_Hw.txMsg);
    Can_Hw.txMsg.messageId = pdu.id;
    Can_Hw.txMsg.dataLengthCode = Can_BytesToDlc(pdu.dlc);

    Can_Hw.txMsg.messageIdLength =
        (pdu.idType == CAN_ID_EXTENDED) ? IfxCan_MessageIdLength_extended : IfxCan_MessageIdLength_standard;

    Can_Hw.txMsg.frameMode =
        (pdu.frameType == CAN_FRAME_FD) ? IfxCan_FrameMode_fdLongAndFast : IfxCan_FrameMode_standard;

    if (IfxCan_Can_sendMessage(node, &Can_Hw.txMsg, (uint32*)data) == TRUE)
    {
        CanIf_TxConfirmation(pdu.swPduHandle);
    }
}

static void Can_ProcessRx(void)
{
    Can_FrameType frame;

    while (Can_RxQueuePop(&frame) == E_OK)
    {
        CanIf_RxIndication(&frame);
    }
}

void Can_MainFunction(void)
{
    if (IfxCan_Node_getBusOffStatus(Can_Hw.nodeClassic.node) != 0u)
    {
        Can_ControllerState[CAN_CONTROLLER_CLASSIC] = CAN_BUS_OFF;
        CanIf_ControllerBusOff(CAN_CONTROLLER_CLASSIC);
    }

    if (IfxCan_Node_getBusOffStatus(Can_Hw.nodeFd.node) != 0u)
    {
        Can_ControllerState[CAN_CONTROLLER_FD] = CAN_BUS_OFF;
        CanIf_ControllerBusOff(CAN_CONTROLLER_FD);
    }

    Can_ProcessRx();
    Can_ProcessTx();
}

static void Can_ReadRxFifo(uint8 controllerId)
{
    Can_FrameType frame;
    IfxCan_Can_Node* node;

    node = (controllerId == CAN_CONTROLLER_CLASSIC) ? &Can_Hw.nodeClassic : &Can_Hw.nodeFd;

    while (IfxCan_Can_getRxFifo0FillLevel(node) > 0u)
    {
        memset(&frame, 0, sizeof(frame));
        memset(Can_Hw.rxData, 0, sizeof(Can_Hw.rxData));

        IfxCan_Can_readMessage(node, &Can_Hw.rxMsg, (uint32*)Can_Hw.rxData);

        frame.controllerId = controllerId;
        frame.id = Can_Hw.rxMsg.messageId;
        frame.idType = (Can_Hw.rxMsg.messageIdLength == IfxCan_MessageIdLength_extended) ? CAN_ID_EXTENDED : CAN_ID_STANDARD;
        frame.frameType = (Can_Hw.rxMsg.frameMode == IfxCan_FrameMode_standard) ? CAN_FRAME_CLASSIC : CAN_FRAME_FD;
        frame.dlc = Can_DlcToBytes(Can_Hw.rxMsg.dataLengthCode);

        if (frame.dlc > CAN_MAX_DLC)
        {
            frame.dlc = CAN_MAX_DLC;
        }

        memcpy(frame.data, Can_Hw.rxData, frame.dlc);
        Can_RxQueuePush(&frame);
    }
}

void Can_IsrRxClassic(void)
{
    IfxCan_Node_clearInterruptFlag(Can_Hw.nodeClassic.node, IfxCan_Interrupt_rxFifo0NewMessage);
    Can_ReadRxFifo(CAN_CONTROLLER_CLASSIC);
}

void Can_IsrRxFd(void)
{
    IfxCan_Node_clearInterruptFlag(Can_Hw.nodeFd.node, IfxCan_Interrupt_rxFifo0NewMessage);
    Can_ReadRxFifo(CAN_CONTROLLER_FD);
}

void Can_IsrBusOffClassic(void)
{
    Can_ControllerState[CAN_CONTROLLER_CLASSIC] = CAN_BUS_OFF;
    CanIf_ControllerBusOff(CAN_CONTROLLER_CLASSIC);
}

void Can_IsrBusOffFd(void)
{
    Can_ControllerState[CAN_CONTROLLER_FD] = CAN_BUS_OFF;
    CanIf_ControllerBusOff(CAN_CONTROLLER_FD);
}

Can_ControllerStateType Can_GetControllerState(uint8 controllerId)
{
    if (controllerId >= CAN_NUM_CONTROLLERS)
    {
        return CAN_UNINIT;
    }

    return Can_ControllerState[controllerId];
}
