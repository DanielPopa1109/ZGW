#include "SoAd.h"

typedef struct
{
    SoAd_StateType state;
    TcpIp_SocketIdType sock;
    uint8_t isServer;
} SoAd_SoConType;

static SoAd_SoConType SoAd_Connections[SOAD_MAX_CONNECTIONS];
static const SoAd_ConfigType *SoAd_Cfg;

void SoAd_Init(const SoAd_ConfigType *cfg)
{
    SoAd_Cfg = cfg;

    for (uint32_t i = 0; i < SOAD_MAX_CONNECTIONS; i++)
    {
        SoAd_Connections[i].state = SOAD_SOCON_CLOSED;
        SoAd_Connections[i].sock = TCPIP_INVALID_SOCKET;
        SoAd_Connections[i].isServer = 1u;
    }
}

uint8_t SoAd_OpenSoCon(uint8_t id)
{
    if (id >= SOAD_MAX_CONNECTIONS)
    {
        return 0u;
    }

    SoAd_SoConType *c = &SoAd_Connections[id];

    c->sock = TcpIp_Create(1u);

    if (c->sock == TCPIP_INVALID_SOCKET)
    {
        return 0u;
    }

    if (TcpIp_Bind(c->sock, SoAd_Cfg[id].port) != 0)
    {
        TcpIp_Close(c->sock);
        return 0u;
    }

    TcpIp_Listen(c->sock);

    c->state = SOAD_SOCON_OPEN;

    return 1u;
}

void SoAd_CloseSoCon(uint8_t id)
{
    if (id >= SOAD_MAX_CONNECTIONS)
    {
        return;
    }

    SoAd_SoConType *c = &SoAd_Connections[id];

    if (c->sock != TCPIP_INVALID_SOCKET)
    {
        TcpIp_Close(c->sock);
    }

    c->state = SOAD_SOCON_CLOSED;
}

void SoAd_MainFunction(void)
{
    for (uint32_t i = 0; i < SOAD_MAX_CONNECTIONS; i++)
    {
        SoAd_SoConType *c = &SoAd_Connections[i];

        if (c->state == SOAD_SOCON_OPEN)
        {
            int newSock = TcpIp_Accept(c->sock);

            if (newSock >= 0)
            {
                c->sock = newSock;
                c->state = SOAD_SOCON_CONNECTED;
            }
        }
        else if (c->state == SOAD_SOCON_CONNECTED)
        {
            uint8_t buffer[512];

            int32_t len = TcpIp_Recv(c->sock, buffer, sizeof(buffer));

            if (len == 0)
            {
                SoAd_CloseSoCon(i);
            }
            else if (len > 0)
            {
                /* upper layer hook */
            }
        }
    }
}

int32_t SoAd_Send(uint8_t id, const uint8_t *data, uint16_t len)
{
    if (id >= SOAD_MAX_CONNECTIONS)
    {
        return -1;
    }

    SoAd_SoConType *c = &SoAd_Connections[id];

    if (c->state != SOAD_SOCON_CONNECTED)
    {
        return -1;
    }

    return TcpIp_Send(c->sock, data, len);
}
