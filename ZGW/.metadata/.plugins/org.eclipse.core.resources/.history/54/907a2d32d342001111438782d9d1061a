/* PduR.c */
#include "PduR.h"
#include <string.h>

typedef struct
{
    PduIdType sourcePduId;
    PduIdType destPduId;
} PduR_RouteType;

static const PduR_RouteType PduR_CanTpToDcm[] =
{
    { 0u, 0u },
    { 1u, 1u },
    { 2u, 2u },
    { 3u, 3u }
};

static const PduR_RouteType PduR_DcmToCanTp[] =
{
    { 0u, 0u },
    { 1u, 1u }
};

static const PduR_RouteType PduR_LinTpToDcm[] =
{
    { 0u, 4u }
};

static const PduR_RouteType PduR_DcmToLinTp[] =
{
    { 4u, 0u }
};

void PduR_LinTpRxIndication(PduIdType RxPduId, const uint8* data, PduLengthType len)
{
    uint8 i;
    Dcm_PduInfoType info;
    Dcm_PduLengthType bufferSize;

    for (i = 0u; i < PDUR_LINTP_TO_DCM_CHANNELS; i++)
    {
        if (PduR_LinTpToDcm[i].sourcePduId == RxPduId)
        {
            info.SduDataPtr = (uint8*)data;
            info.SduLength = len;

            if (Dcm_StartOfReception(PduR_LinTpToDcm[i].destPduId, &info, len, &bufferSize) == BUFREQ_OK)
            {
                if (Dcm_CopyRxData(PduR_LinTpToDcm[i].destPduId, &info, &bufferSize) == BUFREQ_OK)
                {
                    Dcm_TpRxIndication(PduR_LinTpToDcm[i].destPduId, NTFRSLT_OK);
                }
                else
                {
                    Dcm_TpRxIndication(PduR_LinTpToDcm[i].destPduId, NTFRSLT_E_NOT_OK);
                }
            }

            return;
        }
    }
}

void PduR_LinTpTxConfirmation(PduIdType TxPduId, Std_ReturnType result)
{
    uint8 i;

    for (i = 0u; i < PDUR_DCM_TO_LINTP_CHANNELS; i++)
    {
        if (PduR_DcmToLinTp[i].destPduId == TxPduId)
        {
            Dcm_TpTxConfirmation(
                PduR_DcmToLinTp[i].sourcePduId,
                (result == E_OK) ? NTFRSLT_OK : NTFRSLT_E_NOT_OK
            );
            return;
        }
    }
}

Std_ReturnType PduR_LinTpTransmit(PduIdType LinTpTxPduId, const uint8* data, PduLengthType len)
{
    return LinTp_Transmit(LinTpTxPduId, data, len);
}

