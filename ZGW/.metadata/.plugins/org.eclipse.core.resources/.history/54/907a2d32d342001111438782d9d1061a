    {
        if (PduR_DcmToCanTp[i].sourcePduId == DcmTxPduId)
        {
            return CanTp_Transmit(PduR_DcmToCanTp[i].destPduId, data, len);
        }
    }

    return E_NOT_OK;
}

/* DCM lower-layer TX hook */
Std_ReturnType Dcm_LoTransmit(Dcm_PduIdType txPduId, Dcm_PduLengthType len)
{
    static uint8 txBuffer[DCM_MAX_RESPONSE_LEN];
    Dcm_PduInfoType info;
    Dcm_PduLengthType available;
    PduLengthType copied;

    copied = 0u;

    while (copied < len)
    {
        info.SduDataPtr = &txBuffer[copied];
        info.SduLength = (Dcm_PduLengthType)(len - copied);

        if (Dcm_CopyTxData(txPduId, &info, &available) != BUFREQ_OK)
        {
            return E_NOT_OK;
        }

        copied = len;
    }

    return PduR_DcmTransmit(txPduId, txBuffer, len);
}
