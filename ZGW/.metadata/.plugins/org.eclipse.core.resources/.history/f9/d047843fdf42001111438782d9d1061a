#include "CanSM.h"
#include "Can.h"
#include "CanIf.h"

#define CANSM_RECOVERY_TICKS 200u

static CanSM_StateType CanSM_State[CAN_NUM_CONTROLLERS];
static uint16 CanSM_RecoveryTimer[CAN_NUM_CONTROLLERS];

void CanSM_Init(void)
{
    uint8 i;

    for (i = 0u; i < CAN_NUM_CONTROLLERS; i++)
    {
        CanSM_State[i] = CANSM_FULL_COMMUNICATION;
        CanSM_RecoveryTimer[i] = 0u;
    }
}

Std_ReturnType CanSM_RequestComMode(uint8 ControllerId, uint8 FullCom)
{
    if (ControllerId >= CAN_NUM_CONTROLLERS)
    {
        return E_NOT_OK;
    }

    if (FullCom != 0u)
    {
        (void)Can_SetControllerMode(ControllerId, CAN_READY);
        (void)CanIf_SetPduMode(ControllerId, CANIF_PDU_MODE_ONLINE);
        CanSM_State[ControllerId] = CANSM_FULL_COMMUNICATION;
    }
    else
    {
        (void)CanIf_SetPduMode(ControllerId, CANIF_PDU_MODE_OFFLINE);
        (void)Can_SetControllerMode(ControllerId, CAN_SLEEP);
        CanSM_State[ControllerId] = CANSM_NO_COMMUNICATION;
    }

    return E_OK;
}

void CanSM_ControllerBusOff(uint8 ControllerId)
{
    if (ControllerId < CAN_NUM_CONTROLLERS)
    {
        CanSM_State[ControllerId] = CANSM_BUS_OFF_RECOVERY;
        CanSM_RecoveryTimer[ControllerId] = CANSM_RECOVERY_TICKS;
    }
}

void CanSM_MainFunction(void)
{
    uint8 i;

    for (i = 0u; i < CAN_NUM_CONTROLLERS; i++)
    {
        if (CanSM_State[i] == CANSM_BUS_OFF_RECOVERY)
        {
            if (CanSM_RecoveryTimer[i] > 0u)
            {
                CanSM_RecoveryTimer[i]--;
            }
            else
            {
                (void)Can_SetControllerMode(i, CAN_READY);
                (void)CanIf_SetPduMode(i, CANIF_PDU_MODE_ONLINE);
                CanSM_State[i] = CANSM_FULL_COMMUNICATION;
            }
        }
    }
}

CanSM_StateType CanSM_GetState(uint8 ControllerId)
{
    if (ControllerId >= CAN_NUM_CONTROLLERS)
    {
        return CANSM_UNINIT;
    }

    return CanSM_State[ControllerId];
}
