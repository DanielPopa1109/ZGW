#define Ifx_Lwip_timerIncr(var, PERIOD, FLAG) \
{                                             \
  var += 1;                                   \
  if (var >= PERIOD)                          \
  {                                           \
    var         = 0;                          \
    timerFlags |= FLAG;                       \
  }                                           \
}

