#include <string.h>
#include "Ifx_Types.h"

#include "lwip/init.h"
#include "lwip/netif.h"
#include "lwip/ip4_addr.h"
#include "lwip/tcp.h"
#include "lwip/udp.h"
#include "lwip/pbuf.h"
#include "lwip/timeouts.h"
#include "lwip/dhcp.h"
#include "lwip/etharp.h"

#include "lwip_geth.h"

#define DOIP_TCP_PORT                    13400u
#define DOIP_UDP_PORT                    13400u

#define FBL_ETH_RX_QUEUE_DEPTH           4u
#define FBL_ETH_RX_BUF_SIZE              1600u

#define FBL_ETH_USE_DHCP                 0u

#define FBL_ETH_STATIC_IP0               192u
#define FBL_ETH_STATIC_IP1               168u
#define FBL_ETH_STATIC_IP2               1u
#define FBL_ETH_STATIC_IP3               88u

#define FBL_ETH_NETMASK0                 255u
#define FBL_ETH_NETMASK1                 255u
#define FBL_ETH_NETMASK2                 255u
#define FBL_ETH_NETMASK3                 0u

#define FBL_ETH_GATEWAY0                 192u
#define FBL_ETH_GATEWAY1                 168u
#define FBL_ETH_GATEWAY2                 1u
#define FBL_ETH_GATEWAY3                 1u

#ifndef FBL_ETHERNETIF_INPUT_FUNC
#define FBL_ETHERNETIF_INPUT_FUNC        ethernetif_input
#endif

#ifndef FBL_ETHERNETIF_POLL_FUNC
#define FBL_ETHERNETIF_POLL_FUNC()       do { } while(0)
#endif

extern err_t ethernetif_init(struct netif *netif);
extern void FBL_ETHERNETIF_INPUT_FUNC(struct netif *netif);

typedef struct
{
    uint8 data[FBL_ETH_RX_BUF_SIZE];
    uint16 len;
} FblEth_RxItemType;

static struct netif g_netif;
static struct tcp_pcb *g_tcpListen;
static struct tcp_pcb *g_tcpActive;
static struct udp_pcb *g_udp;

static FblEth_RxItemType g_tcpQ[FBL_ETH_RX_QUEUE_DEPTH];
static FblEth_RxItemType g_udpQ[FBL_ETH_RX_QUEUE_DEPTH];

static volatile uint8 g_tcpWr;
static volatile uint8 g_tcpRd;
static volatile uint8 g_tcpCnt;

static volatile uint8 g_udpWr;
static volatile uint8 g_udpRd;
static volatile uint8 g_udpCnt;

static ip_addr_t g_udpRemoteIp;
static uint16 g_udpRemotePort;
static uint8 g_udpRemoteValid;

static uint8 g_initDone;

static void FblEth_CopyPbuf(uint8 *dst, uint16 *dstLen, const struct pbuf *p)
{
    const struct pbuf *q;
    uint16 copied = 0u;

    for(q = p; q != NULL; q = q->next)
    {
        uint16 chunk = q->len;

        if((copied + chunk) > FBL_ETH_RX_BUF_SIZE)
        {
            chunk = (uint16)(FBL_ETH_RX_BUF_SIZE - copied);
        }

        if(chunk > 0u)
        {
            memcpy(&dst[copied], q->payload, chunk);
            copied = (uint16)(copied + chunk);
        }

        if(copied >= FBL_ETH_RX_BUF_SIZE)
        {
            break;
        }
    }

    *dstLen = copied;
}

static void FblEth_QueueTcp(const struct pbuf *p)
{
    if(g_tcpCnt >= FBL_ETH_RX_QUEUE_DEPTH)
    {
        return;
    }

    FblEth_CopyPbuf(g_tcpQ[g_tcpWr].data, &g_tcpQ[g_tcpWr].len, p);
    g_tcpWr = (uint8)((g_tcpWr + 1u) % FBL_ETH_RX_QUEUE_DEPTH);
    g_tcpCnt++;
}

static void FblEth_QueueUdp(const struct pbuf *p)
{
    if(g_udpCnt >= FBL_ETH_RX_QUEUE_DEPTH)
    {
        return;
    }

    FblEth_CopyPbuf(g_udpQ[g_udpWr].data, &g_udpQ[g_udpWr].len, p);
    g_udpWr = (uint8)((g_udpWr + 1u) % FBL_ETH_RX_QUEUE_DEPTH);
    g_udpCnt++;
}

static err_t FblEth_TcpRecvCb(void *arg, struct tcp_pcb *tpcb, struct pbuf *p, err_t err)
{
    (void)arg;

    if((err != ERR_OK) || (tpcb == NULL))
    {
        if(p != NULL)
        {
            pbuf_free(p);
        }

        return ERR_OK;
    }

    if(p == NULL)
    {
        if(g_tcpActive == tpcb)
        {
            g_tcpActive = NULL;
        }

        tcp_arg(tpcb, NULL);
        tcp_recv(tpcb, NULL);
        tcp_err(tpcb, NULL);
        tcp_close(tpcb);
        return ERR_OK;
    }

    FblEth_QueueTcp(p);
    tcp_recved(tpcb, p->tot_len);
    pbuf_free(p);

    return ERR_OK;
}

static void FblEth_TcpErrCb(void *arg, err_t err)
{
    (void)arg;
    (void)err;

    g_tcpActive = NULL;
}

static err_t FblEth_TcpAcceptCb(void *arg, struct tcp_pcb *newPcb, err_t err)
{
    (void)arg;

    if((err != ERR_OK) || (newPcb == NULL))
    {
        return ERR_VAL;
    }

    if(g_tcpActive != NULL)
    {
        tcp_abort(newPcb);
        return ERR_ABRT;
    }

    g_tcpActive = newPcb;

    tcp_setprio(newPcb, TCP_PRIO_NORMAL);
    tcp_arg(newPcb, NULL);
    tcp_recv(newPcb, FblEth_TcpRecvCb);
    tcp_err(newPcb, FblEth_TcpErrCb);
    tcp_nagle_disable(newPcb);

    return ERR_OK;
}

static void FblEth_UdpRecvCb(void *arg,
                             struct udp_pcb *upcb,
                             struct pbuf *p,
                             const ip_addr_t *addr,
                             u16_t port)
{
    (void)arg;
    (void)upcb;

    if((p == NULL) || (addr == NULL))
    {
        return;
    }

    FblEth_QueueUdp(p);
    ip_addr_copy(g_udpRemoteIp, *addr);
    g_udpRemotePort = port;
    g_udpRemoteValid = 1u;

    pbuf_free(p);
}

static void FblEth_StartTcp(void)
{
    err_t err;

    g_tcpListen = tcp_new_ip_type(IPADDR_TYPE_ANY);

    if(g_tcpListen == NULL)
    {
        return;
    }

    err = tcp_bind(g_tcpListen, IP_ANY_TYPE, DOIP_TCP_PORT);

    if(err != ERR_OK)
    {
        tcp_close(g_tcpListen);
        g_tcpListen = NULL;
        return;
    }

    g_tcpListen = tcp_listen(g_tcpListen);

    if(g_tcpListen == NULL)
    {
        return;
    }

    tcp_accept(g_tcpListen, FblEth_TcpAcceptCb);
}

static void FblEth_StartUdp(void)
{
    err_t err;

    g_udp = udp_new_ip_type(IPADDR_TYPE_ANY);

    if(g_udp == NULL)
    {
        return;
    }

    err = udp_bind(g_udp, IP_ANY_TYPE, DOIP_UDP_PORT);

    if(err != ERR_OK)
    {
        udp_remove(g_udp);
        g_udp = NULL;
        return;
    }

    udp_recv(g_udp, FblEth_UdpRecvCb, NULL);
}

void FblEth_Init(void)
{
    ip4_addr_t ip;
    ip4_addr_t mask;
    ip4_addr_t gw;

    if(g_initDone != 0u)
    {
        return;
    }

    memset(&g_netif, 0u, sizeof(g_netif));
    memset(g_tcpQ, 0u, sizeof(g_tcpQ));
    memset(g_udpQ, 0u, sizeof(g_udpQ));

    g_tcpWr = 0u;
    g_tcpRd = 0u;
    g_tcpCnt = 0u;
    g_udpWr = 0u;
    g_udpRd = 0u;
    g_udpCnt = 0u;
    g_udpRemoteValid = 0u;

    lwip_init();

#if (FBL_ETH_USE_DHCP != 0u)
    ip4_addr_set_zero(&ip);
    ip4_addr_set_zero(&mask);
    ip4_addr_set_zero(&gw);
#else
    IP4_ADDR(&ip, FBL_ETH_STATIC_IP0, FBL_ETH_STATIC_IP1, FBL_ETH_STATIC_IP2, FBL_ETH_STATIC_IP3);
    IP4_ADDR(&mask, FBL_ETH_NETMASK0, FBL_ETH_NETMASK1, FBL_ETH_NETMASK2, FBL_ETH_NETMASK3);
    IP4_ADDR(&gw, FBL_ETH_GATEWAY0, FBL_ETH_GATEWAY1, FBL_ETH_GATEWAY2, FBL_ETH_GATEWAY3);
#endif

    if(netif_add(&g_netif, &ip, &mask, &gw, NULL, ethernetif_init, netif_input) == NULL)
    {
        return;
    }

    netif_set_default(&g_netif);
    netif_set_up(&g_netif);

#if (FBL_ETH_USE_DHCP != 0u)
    dhcp_start(&g_netif);
#endif

    FblEth_StartTcp();
    FblEth_StartUdp();

    g_initDone = 1u;
}

void FblEth_MainFunction(void)
{
    if(g_initDone == 0u)
    {
        return;
    }

    FBL_ETHERNETIF_INPUT_FUNC(&g_netif);
    FBL_ETHERNETIF_POLL_FUNC();
    sys_check_timeouts();

#if (FBL_ETH_USE_DHCP != 0u)
    if((netif_is_up(&g_netif) != 0) && ip4_addr_isany_val(*netif_ip4_addr(&g_netif)))
    {
        sys_check_timeouts();
    }
#endif
}

uint8 FblEth_TcpReceive(uint8 *buf, uint16 *len)
{
    if((buf == NULL) || (len == NULL))
    {
        return 0u;
    }

    if(g_tcpCnt == 0u)
    {
        return 0u;
    }

    memcpy(buf, g_tcpQ[g_tcpRd].data, g_tcpQ[g_tcpRd].len);
    *len = g_tcpQ[g_tcpRd].len;

    g_tcpQ[g_tcpRd].len = 0u;
    g_tcpRd = (uint8)((g_tcpRd + 1u) % FBL_ETH_RX_QUEUE_DEPTH);
    g_tcpCnt--;

    return 1u;
}

uint8 FblEth_UdpReceive(uint8 *buf, uint16 *len)
{
    if((buf == NULL) || (len == NULL))
    {
        return 0u;
    }

    if(g_udpCnt == 0u)
    {
        return 0u;
    }

    memcpy(buf, g_udpQ[g_udpRd].data, g_udpQ[g_udpRd].len);
    *len = g_udpQ[g_udpRd].len;

    g_udpQ[g_udpRd].len = 0u;
    g_udpRd = (uint8)((g_udpRd + 1u) % FBL_ETH_RX_QUEUE_DEPTH);
    g_udpCnt--;

    return 1u;
}

void FblEth_TcpSend(const uint8 *buf, uint16 len)
{
    err_t err;

    if((g_tcpActive == NULL) || (buf == NULL) || (len == 0u))
    {
        return;
    }

    if(tcp_sndbuf(g_tcpActive) < len)
    {
        return;
    }

    err = tcp_write(g_tcpActive, buf, len, TCP_WRITE_FLAG_COPY);

    if(err == ERR_OK)
    {
        tcp_output(g_tcpActive);
    }
}

void FblEth_UdpSend(const uint8 *buf, uint16 len)
{
    struct pbuf *p;
    ip_addr_t broadcastIp;

    if((g_udp == NULL) || (buf == NULL) || (len == 0u))
    {
        return;
    }

    p = pbuf_alloc(PBUF_TRANSPORT, len, PBUF_RAM);

    if(p == NULL)
    {
        return;
    }

    memcpy(p->payload, buf, len);

    if(g_udpRemoteValid != 0u)
    {
        udp_sendto(g_udp, p, &g_udpRemoteIp, g_udpRemotePort);
    }
    else
    {
        ip_addr_set_ip4_u32(&broadcastIp, PP_HTONL(IPADDR_BROADCAST));
        udp_sendto(g_udp, p, &broadcastIp, DOIP_UDP_PORT);
    }

    pbuf_free(p);
}
