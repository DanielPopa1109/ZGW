/* ============================== Main ============================== */
void core0_main(void)
{
    Fbl_PlatformInit();
    FblRamUpdater_Init();
    Fbl_IsoTpInit();

    if(g_FblTransportSelect == FBL_TRANSPORT_CANFD)
    {
        Fbl_CanFdInit();
    }
    else if(g_FblTransportSelect == FBL_TRANSPORT_ETH)
    {
        FblEth_Init();
    }
    else
    {
        g_FblTransportSelect = FBL_TRANSPORT_CANFD;
        Fbl_CanFdInit();
    }

    if(g_FblForceStay == 0u)
    {
        FblRamUpdater_JumpToApplication(APP_START_NCACHED);
    }

    while(1)
    {
        if(g_FblTransportSelect == FBL_TRANSPORT_CANFD)
        {
            Fbl_IsoTpMainFunction();
        }
        else
        {
            FblEth_MainFunction();
            Fbl_DoIpMainFunction();
        }
    }
}

