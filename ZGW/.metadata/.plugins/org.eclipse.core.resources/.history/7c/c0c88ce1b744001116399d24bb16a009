/* Cpu0_Main.c - AURIX TC375 single-core FBL control layer
 * Lab-grade baseline: CAN-FD ISO-TP + Ethernet DoIP-style update routing.
 * Toolchain: TASKING + iLLD 4.0.4.
 * No OS. CPU0 only.
 *
 * Flash layout:
 *   FBL: 0xA0000000 - 0xA001FFFF, 128 KiB
 *   APP: 0xA0020000 - 0xA07FFFFF
 *
 * Update transport selection:
 *   g_FblTransportSelect = 1 => CAN-FD ISO-TP
 *   g_FblTransportSelect = 2 => Ethernet DoIP/TCP
 *
 * Ethernet note:
 *   This file implements DoIP framing and UDS routing.
 *   Board-specific GETH/lwIP bring-up is isolated behind FblEth_* hooks.
 */

