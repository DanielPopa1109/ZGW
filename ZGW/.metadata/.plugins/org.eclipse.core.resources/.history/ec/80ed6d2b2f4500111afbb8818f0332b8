#include "Crc.h"

uint32_t Crc_CalculateCRC32(const uint8_t* data,
                           uint32_t length,
                           uint32_t startValue,
                           uint8_t isFirstCall)
{
    uint32_t crc = isFirstCall ? 0xFFFFFFFFu : startValue;

    for (uint32_t i = 0; i < length; i++)
    {
        crc ^= data[i];
        for (uint8_t j = 0; j < 8; j++)
        {
            crc = (crc >> 1) ^ (0xEDB88320u & (-(crc & 1)));
        }
    }
    return ~crc;
}
