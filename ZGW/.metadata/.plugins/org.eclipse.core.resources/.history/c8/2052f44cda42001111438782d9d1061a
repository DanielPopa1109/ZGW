#include "LinSM.h"

static LinSM_StateType LinSM_State[LIN_MAX_CHANNELS];

void LinSM_Init(void)
{
    uint8 ch;

    for (ch = 0u; ch < LIN_MAX_CHANNELS; ch++)
    {
        LinSM_State[ch] = LINSM_FULL_COMMUNICATION;
    }
}

Std_ReturnType LinSM_RequestComMode(Lin_ChannelType Channel, LinSM_StateType Mode)
{
    if (Channel >= LIN_MAX_CHANNELS)
    {
        return E_NOT_OK;
    }

    if (Mode == LINSM_SLEEP)
    {
        if (Lin_GoToSleep(Channel) != E_OK)
        {
            return E_NOT_OK;
        }
    }
    else if (Mode == LINSM_FULL_COMMUNICATION)
    {
        if (Lin_Wakeup(Channel) != E_OK)
        {
            return E_NOT_OK;
        }
    }
    else
    {
        /* No hardware transition needed. */
    }

    LinSM_State[Channel] = Mode;
    return E_OK;
}

LinSM_StateType LinSM_GetCurrentComMode(Lin_ChannelType Channel)
{
    if (Channel >= LIN_MAX_CHANNELS)
    {
        return LINSM_UNINIT;
    }

    return LinSM_State[Channel];
}

void LinSM_MainFunction(void)
{
}
