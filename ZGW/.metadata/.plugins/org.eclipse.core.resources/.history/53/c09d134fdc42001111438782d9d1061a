#include "Com.h"
#include "PduR.h"
#include <string.h>
#include "CanIf.h"

typedef struct
{
    PduIdType signalId;
    PduIdType txPduId;
    uint8 byteOffset;
    uint8 bitSize;
    uint8 dirty;
    uint8 buffer[COM_MAX_IPDU_LEN];
    PduLengthType len;
} Com_SignalType;

static Com_SignalType Com_SignalTable[] =
{
    { 0u, CANIF_PDU_APP_TX, 0u, 8u, 0u, {0u}, 8u }
};

void Com_Init(void)
{
    memset(Com_SignalTable, 0, sizeof(Com_SignalTable));
    Com_SignalTable[0].signalId = 0u;
    Com_SignalTable[0].txPduId = CANIF_PDU_APP_TX;
    Com_SignalTable[0].byteOffset = 0u;
    Com_SignalTable[0].bitSize = 8u;
    Com_SignalTable[0].len = 8u;
}

Std_ReturnType Com_SendSignal(PduIdType SignalId, const void* SignalDataPtr)
{
    uint8 i;

    if (SignalDataPtr == NULL_PTR)
    {
        return E_NOT_OK;
    }

    for (i = 0u; i < (uint8)(sizeof(Com_SignalTable) / sizeof(Com_SignalTable[0])); i++)
    {
        if (Com_SignalTable[i].signalId == SignalId)
        {
            Com_SignalTable[i].buffer[Com_SignalTable[i].byteOffset] = *((const uint8*)SignalDataPtr);
            Com_SignalTable[i].dirty = 1u;
            return E_OK;
        }
    }

    return E_NOT_OK;
}

void Com_MainFunctionTx(void)
{
    uint8 i;

    for (i = 0u; i < (uint8)(sizeof(Com_SignalTable) / sizeof(Com_SignalTable[0])); i++)
    {
        if (Com_SignalTable[i].dirty != 0u)
        {
            (void)PduR_ComTransmit(Com_SignalTable[i].txPduId,
                                   Com_SignalTable[i].buffer,
                                   Com_SignalTable[i].len);
            Com_SignalTable[i].dirty = 0u;
        }
    }
}

void Com_MainFunctionRx(void)
{
}

void Com_RxIndication(PduIdType RxPduId, const uint8* data, PduLengthType len)
{
    (void)RxPduId;
    (void)data;
    (void)len;
}

void Com_TxConfirmation(PduIdType TxPduId)
{
    (void)TxPduId;
}
