#ifndef LIN_H
#define LIN_H

#include "Std_Types.h"
#include "Lin_Cfg.h"

typedef uint8 Lin_ChannelType;

typedef enum
{
    LIN_CS_CLASSIC = 0u,
    LIN_CS_ENHANCED = 1u
} Lin_ChecksumType;

typedef enum
{
    LIN_FRAMERESPONSE_TX = 0u,
    LIN_FRAMERESPONSE_RX = 1u,
    LIN_FRAMERESPONSE_IGNORE = 2u
} Lin_FrameResponseType;

typedef enum
{
    LIN_UNINIT = 0u,
    LIN_INIT,
    LIN_SLEEP,
    LIN_OPERATIONAL,
    LIN_TX_BUSY,
    LIN_RX_BUSY,
    LIN_ERROR
} Lin_StatusType;

typedef struct
{
    uint8 id;
    uint8 dlc;
    uint8 data[LIN_MAX_FRAME_DATA_LEN];
    Lin_ChecksumType checksumType;
    Lin_FrameResponseType responseType;
} Lin_PduType;

typedef struct
{
    Ifx_ASCLIN* asclin;
    uint32 baudrate;
} Lin_ChannelConfigType;

typedef struct
{
    const Lin_ChannelConfigType* channels;
    uint8 numChannels;
} Lin_ConfigType;

void Lin_Init(const Lin_ConfigType* ConfigPtr);
Std_ReturnType Lin_SendFrame(Lin_ChannelType Channel, const Lin_PduType* PduInfoPtr);
Std_ReturnType Lin_GoToSleep(Lin_ChannelType Channel);
Std_ReturnType Lin_Wakeup(Lin_ChannelType Channel);
Lin_StatusType Lin_GetStatus(Lin_ChannelType Channel, uint8* LinSduPtr);
void Lin_MainFunction(void);

/* IRQ hooks called by ASCLIN ISR layer */
void Lin_TxIsr(Lin_ChannelType Channel);
void Lin_RxIsr(Lin_ChannelType Channel);
void Lin_ErrIsr(Lin_ChannelType Channel);

extern const Lin_ConfigType Lin_Config;

#endif
