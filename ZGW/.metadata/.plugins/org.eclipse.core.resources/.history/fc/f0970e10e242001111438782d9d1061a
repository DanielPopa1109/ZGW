#include "PduR.h"
#include "CanTp.h"
#include "LinTp.h"
#include "Dcm.h"
#include "Com.h"
#include <string.h>

typedef struct
{
    uint8 buffer[PDUR_MAX_TP_BUFFER];
    PduLengthType len;
    PduLengthType offset;
    uint8 active;
} PduR_TpBufferType;

static PduR_TpBufferType PduR_CanTpRxBuf;
static PduR_TpBufferType PduR_LinTpRxBuf;

void PduR_Init(void)
{
    memset(&PduR_CanTpRxBuf, 0, sizeof(PduR_CanTpRxBuf));
    memset(&PduR_LinTpRxBuf, 0, sizeof(PduR_LinTpRxBuf));
}

Std_ReturnType PduR_ComTransmit(PduIdType TxPduId, const uint8* data, PduLengthType len)
{
    return CanIf_Transmit(TxPduId, data, len);
}

Std_ReturnType PduR_DcmTransmit(PduIdType TxPduId, const uint8* data, PduLengthType len)
{
    if ((data == NULL_PTR) || (len == 0u))
    {
        return E_NOT_OK;
    }

    switch (TxPduId)
    {
        case 0u:
        case 1u:
            return CanTp_Transmit(TxPduId, data, len);

        case 2u:
        case 3u:
            if (len > 255u)
            {
                return E_NOT_OK;
            }

            return LinTp_Transmit(TxPduId, data, len);

        default:
            return E_NOT_OK;
    }
}

Std_ReturnType PduR_CanTpStartOfReception(PduIdType id, PduLengthType len)
{
    (void)id;

    if (len > PDUR_MAX_TP_BUFFER)
    {
        return E_NOT_OK;
    }

    PduR_CanTpRxBuf.len = len;
    PduR_CanTpRxBuf.offset = 0u;
    PduR_CanTpRxBuf.active = TRUE;
    return E_OK;
}

Std_ReturnType PduR_CanTpCopyRxData(PduIdType id, const uint8* data, PduLengthType len)
{
    (void)id;

    if ((data == NULL_PTR) || (PduR_CanTpRxBuf.active == FALSE) ||
        ((PduR_CanTpRxBuf.offset + len) > PduR_CanTpRxBuf.len))
    {
        return E_NOT_OK;
    }

    memcpy(&PduR_CanTpRxBuf.buffer[PduR_CanTpRxBuf.offset], data, len);
    PduR_CanTpRxBuf.offset = (PduLengthType)(PduR_CanTpRxBuf.offset + len);
    return E_OK;
}

void PduR_CanTpRxIndication(PduIdType id, Std_ReturnType result)
{
    if ((result == E_OK) && (PduR_CanTpRxBuf.active == TRUE))
    {
        Dcm_RxIndication(id, PduR_CanTpRxBuf.buffer, PduR_CanTpRxBuf.len);
    }

    PduR_CanTpRxBuf.active = FALSE;
}

void PduR_CanTpTxConfirmation(PduIdType id, Std_ReturnType result)
{
    Dcm_TxConfirmation(id, result);
}

